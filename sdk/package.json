{
	"name": "@pekempy/fluxer-plugin-sdk",
	"version": "0.1.0",
	"description": "SDK for developing Fluxer plugins — types, validation, and utilities for extending fluxer-api, fluxer-app, and fluxer-admin without modifying upstream source.",
	"author": "pekempy",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./types/*": {
			"types": "./dist/types/*.d.ts",
			"import": "./dist/types/*.js"
		},
		"./helpers/api": {
			"types": "./dist/helpers/api.d.ts",
			"import": "./dist/helpers/api.js"
		},
		"./helpers/app": {
			"types": "./dist/helpers/app.d.ts",
			"import": "./dist/helpers/app.js"
		},
		"./helpers/admin": {
			"types": "./dist/helpers/admin.d.ts",
			"import": "./dist/helpers/admin.js"
		},
		"./context": {
			"types": "./dist/context.d.ts",
			"import": "./dist/context.js"
		},
		"./manifest": {
			"types": "./dist/manifest.d.ts",
			"import": "./dist/manifest.js"
		}
	},
	"files": [
		"dist/"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"clean": "rm -rf dist",
		"prepublishOnly": "pnpm clean && pnpm build",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"yaml": "^2.7.1",
		"zod": "^3.25.67"
	},
	"devDependencies": {
		"@types/node": "^24.0.4",
		"@types/react": "^19.0.0",
		"hono": "4.12.2",
		"react": "^19.0.0",
		"typescript": "^5.8.3",
		"vitest": "^3.2.3"
	},
	"engines": {
		"node": ">=22"
	}
}
